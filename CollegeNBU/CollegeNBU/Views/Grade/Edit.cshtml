@model CollegeNBU.Web.ViewModels.Grade.EditGradeViewModel

@{
    ViewData["Title"] = "Edit Grade";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card login-card shadow border-0">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <h2 class="fw-bold text-center">
                            Edit Grade
                        </h2>

                        <p class="text-muted">
                            Update grade information.
                        </p>

                    </div>

                    <form asp-action="Edit">

                        <input asp-for="Id" type="hidden" />

                        <div class="mb-4">

                            <label asp-for="Value"
                                   class="form-label">
                                Grade
                            </label>

                            <input asp-for="Value"
                                   class="form-control" />

                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100 login-btn">
                            Update Grade
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>