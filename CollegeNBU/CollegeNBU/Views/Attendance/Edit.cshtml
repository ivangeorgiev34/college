@model CollegeNBU.Web.ViewModels.Attendance.EditAttendanceViewModel

@{
    ViewData["Title"] = "Edit Attendance";
}

<div class="container py-5">

    <div class="card login-card shadow-lg border-0">

        <div class="card-body">

            <h2 class="fw-bold mb-2 text-center">
                Edit Attendance
            </h2>

            <p class="login-subtitle">
                Update attendance information.
            </p>

            <form asp-action="Edit">

                <input asp-for="Id" hidden />

                <div class="form-check mb-4">

                    <input asp-for="IsAbsent"
                           class="form-check-input" />

                    <label asp-for="IsAbsent"
                           class="form-check-label">
                        Student Absent
                    </label>

                </div>

                <button type="submit"
                        class="btn btn-primary login-btn w-100">
                    Save Changes
                </button>

            </form>

        </div>

    </div>

</div>