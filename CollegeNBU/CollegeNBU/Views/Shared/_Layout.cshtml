<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - College</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CollegeNBU.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
            <div class="container">
                <a class=" navbar-brand fw-bold fs-4"
                   asp-controller="Home"
                   asp-action="Index">
                    College Manager
                </a>
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse"
                     id="navbarContent">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                            {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="College"
                                   asp-action="Index">
                                    Colleges
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Faculty"
                                   asp-action="Index">
                                    Faculties
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Department"
                                   asp-action="Index">
                                    Departments
                                </a>
                            </li>
                            }
                        @if (User.IsInRole("Rector") || User.IsInRole("Admin"))
                            {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Course"
                                   asp-action="Index">
                                    Courses
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Student"
                                   asp-action="Index">
                                    Students
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Teacher"
                                   asp-action="Index">
                                    Teachers
                                </a>
                            </li>
                            }

                        @if (User.IsInRole("Teacher") || User.IsInRole("Admin") || User.IsInRole("Student"))
                            {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Grade"
                                   asp-action="Index">
                                    Grades
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Attendance"
                                   asp-action="Index">
                                    Attendance
                                </a>
                            </li>
                            }

                        @if (User.IsInRole("Admin"))
                            {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="SemesterProgram"
                                   asp-action="Index">
                                    Semester Programs
                                </a>
                            </li>
                            }
                             @if (User.IsInRole("Rector") || User.IsInRole("Admin"))
                            {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Rector"
                                   asp-action="Dashboard">
                                    Rector Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Statistics"
                                   asp-action="College">
                                    Statistics
                                </a>
                            </li>
                            }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <main>
        @RenderBody()
    </main>
    <footer class="mt-5">
        <div class="container text-center">
            <span>
                © 2026 College | College Management System
            </span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>