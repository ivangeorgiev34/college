@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="container text-center">
        <h1 class="hero-title">
            Manage Your College Efficiently
        </h1>
        <p class="hero-subtitle">
            Centralized management of faculties, departments,
            courses, teachers and students in one platform.
        </p>
        <div class="mt-5">
            <a asp-controller="College"
               asp-action="Index"
               class="btn btn-light btn-lg px-5 me-3">
                Explore Colleges
            </a>
            @if(User.IsInRole("Admin") || User.IsInRole("Rector"))
            {
                <a asp-controller="Statistics"
                   asp-action="College"
                   class="btn btn-outline-light btn-lg px-5">
                    View Statistics
                </a>
            }
        </div>
    </div>
</section>
