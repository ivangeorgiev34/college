@{
    ViewData["Title"] = "Home";
}
<section class="hero-section">
    <div class="container text-center">
        <h1 class="hero-title">
            Manage Your College Efficiently
        </h1>
        <p class="hero-subtitle mx-auto">
            Centralized management of faculties, departments, courses,
            teachers and students in one modern platform.
        </p>
        <div class="mt-5">
            <a class="btn btn-light btn-lg px-5 me-3 fw-semibold">
                Explore Colleges
            </a>
            <a class="btn btn-outline-light btn-lg px-5">
                Learn More
            </a>
        </div>
    </div>
</section>
<div class="container">
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card dashboard-card h-100">
                <div class="card-body text-center">
                    <h4>Colleges</h4>
                    <p>
                        Manage college information, locations and structure.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card dashboard-card h-100">
                <div class="card-body text-center">
                    <h4>Faculties</h4>
                    <p>
                        Organize faculties and departments efficiently.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card dashboard-card h-100">
                <div class="card-body text-center">
                    <h4>Courses</h4>
                    <p>
                        Manage courses and academic programs.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>