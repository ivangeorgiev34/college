@model IEnumerable<CollegeNBU.Web.ViewModels.SemesterProgram.SemesterProgramViewModel>

@{
    ViewData["Title"] = "Semester Programs";
}

<div class="container py-4">

    <div class="text-center mb-4">

        <h2 class="fw-bold text-center">
            Semester Programs
        </h2>

        <p class="text-muted">
            Manage semester study programs by department.
        </p>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create"
               class="btn btn-primary">
                Create Program
            </a>
        }

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead>

                    <tr>
                        <th>Department</th>
                        <th>Courses</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.DepartmentName
                            </td>

                            <td>

                                @foreach (var course in item.Courses)
                                {
                                    <span class="badge bg-primary me-1">
                                        @course
                                    </span>
                                }

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>