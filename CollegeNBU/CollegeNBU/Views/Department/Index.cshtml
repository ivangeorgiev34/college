@model IEnumerable<CollegeNBU.Web.ViewModels.Department.DepartmentViewModel>

@{
    ViewData["Title"] = "Departments";
}

<div class="container py-4">

    <div class="text-center mb-4">

        <h2 class="fw-bold">
            Departments
        </h2>

        <p class="text-muted">
            Manage departments within faculties.
        </p>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create"
               class="btn btn-primary">
                Add Department
            </a>
        }

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Faculty</th>
                        <th>Head Teacher</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.Name</td>

                            <td>@item.FacultyName</td>

                            <td>
                                @(string.IsNullOrEmpty(item.HeadTeacherName)
                                    ? "Not Assigned"
                                    : item.HeadTeacherName)
                            </td>

                            <td class="text-end">

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </a>
                                }
                               

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>