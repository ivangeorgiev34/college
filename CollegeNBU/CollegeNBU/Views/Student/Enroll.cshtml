@model CollegeNBU.Web.ViewModels.Student.EnrollStudentViewModel

@{
    ViewData["Title"] = "Enroll Student";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card login-card shadow-lg border-0">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <h2 class="fw-bold text-center">
                            Enroll Student
                        </h2>

                        <p class="text-muted">
                            Select courses for this student.
                        </p>

                    </div>

                    <form asp-action="Enroll">

                        <input asp-for="StudentId" hidden />

                        <div class="mb-4">

                            <label class="form-label">
                                Courses
                            </label>

                            <select asp-for="SelectedCourseIds"
                                    class="form-select"
                                    multiple
                                    size="10">

                                @foreach (var course in ViewBag.Courses)
                                {
                                    <option value="@course.Id">
                                        @course.Name
                                    </option>
                                }

                            </select>

                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100 login-btn">
                            Save Enrollment
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>