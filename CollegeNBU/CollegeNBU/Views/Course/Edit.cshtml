@model CollegeNBU.Web.ViewModels.Course.EditCourseViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Edit Course";
}

<div class="container py-5">

    <div class="card login-card shadow-lg border-0">

        <div class="card-body">

            <h2 class="fw-bold mb-2 text-center">
                Edit Course
            </h2>

            <p class="login-subtitle">
                Update course information.
            </p>

            <form asp-action="Edit" method="post">

                <input asp-for="Id" hidden />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="mb-3">

                    <label asp-for="Name"
                           class="form-label">
                        Course Name
                    </label>

                    <input asp-for="Name"
                           class="form-control" />

                    <span asp-validation-for="Name"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="Description"
                           class="form-label">
                        Description
                    </label>

                    <textarea asp-for="Description"
                              class="form-control"
                              rows="4">
                    </textarea>

                    <span asp-validation-for="Description"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Department
                    </label>

                    <select asp-for="DepartmentId"
                            class="form-select"
                            asp-items="@(new SelectList(ViewBag.Departments, "Id", "Name"))">

                        <option value="0">
                            Select Department
                        </option>

                    </select>

                    <span asp-validation-for="DepartmentId"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-4">

                    <label class="form-label">
                        Teacher
                    </label>

                    <select asp-for="TeacherId"
                            class="form-select"
                            asp-items="@(new SelectList(ViewBag.Teachers, "Id", "FirstName"))">

                        <option value="0">
                            Select Teacher
                        </option>

                    </select>

                    <span asp-validation-for="TeacherId"
                          class="text-danger">
                    </span>

                </div>

                <button type="submit"
                        class="btn btn-primary login-btn w-100">
                    Save Changes
                </button>

            </form>
        </div>

    </div>

</div>