@model CollegeNBU.ViewModels.College.CollegeViewModel

@{
    ViewData["Title"] = "Edit College";
}

<div class="container py-5">

    <div class="card login-card shadow-lg border-0">

        <div class="card-body">

            <h2 class="fw-bold mb-2 text-center">
                Edit College
            </h2>

            <p class="login-subtitle">
                Update college information.
            </p>

            <form asp-action="Edit">

                <input asp-for="Id" hidden />

                <div class="mb-3">

                    <label asp-for="Name"
                           class="form-label">
                        College Name
                    </label>

                    <input asp-for="Name"
                           class="form-control" />

                    <span asp-validation-for="Name"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-4">

                    <label asp-for="Address"
                           class="form-label">
                        Address
                    </label>

                    <input asp-for="Address"
                           class="form-control" />

                    <span asp-validation-for="Address"
                          class="text-danger">
                    </span>

                </div>

                <button type="submit"
                        class="btn btn-primary login-btn w-100">
                    Save Changes
                </button>

            </form>

        </div>

    </div>

</div>