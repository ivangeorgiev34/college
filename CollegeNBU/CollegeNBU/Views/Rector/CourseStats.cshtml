@model IEnumerable<CollegeNBU.Web.ViewModels.Rector.RectorCourseStatsViewModel>

@{
    ViewData["Title"] = "Course Statistics";
}

<div class="container py-4">

    <div class="text-center mb-4">

        <h2 class="fw-bold text-center">
            Course Statistics
        </h2>

        <p class="text-muted">
            Statistics by course.
        </p>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead>

                    <tr>
                        <th>Course</th>
                        <th>Average Grade</th>
                        <th>Students</th>
                        <th>Absences</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.CourseName</td>

                            <td>
                                @item.AverageGrade.ToString("F2")
                            </td>

                            <td>
                                @item.StudentsCount
                            </td>

                            <td>
                                @item.AbsencesCount
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <div class="text-center mt-4">

        <a asp-action="Dashboard"
           class="btn btn-outline-primary">
            Back to Dashboard
        </a>

    </div>

</div>